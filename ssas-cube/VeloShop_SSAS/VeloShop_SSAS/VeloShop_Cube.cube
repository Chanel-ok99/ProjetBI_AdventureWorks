  <Source dwd:design-time-name="16a4a818-c9bc-4545-a928-563e66af12bc">
    <DataSourceViewID>VeloShop_DSV</DataSourceViewID>
  </Source>
  <MdxScripts>
    <MdxScript dwd:design-time-name="94de85f0-35fa-4a54-bb6f-69ab5147025d">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
La commande CALCULATE contrôle l'agrégation des cellules feuilles dans le cube.
Si la commande CALCULATE est supprimée ou modifiée, les données au sein du cube sont affectées.
Vous devez modifier cette commande uniquement si vous spécifiez manuellement la façon dont le cube est agrégé.
*/
CALCULATE
// Mesure 1 - Marge brute
CREATE MEMBER CURRENTCUBE.[Measures].[Gross Profit] AS
[Measures].[Sales Amount] - [Measures].[Total Product Cost],
FORMAT_STRING = "Currency",
VISIBLE = 1;

// Mesure 2 - Taux de marge
CREATE MEMBER CURRENTCUBE.[Measures].[Gross Margin Pct] AS
IIF([Measures].[Sales Amount] = 0, NULL,
([Measures].[Sales Amount] - [Measures].[Total Product Cost])
/ [Measures].[Sales Amount]),
FORMAT_STRING = "#,##0.00%",
VISIBLE = 1;

// Mesure 3 - Valeur moyenne commande
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Order Value] AS
IIF([Measures].[Internet Order Count] = 0, NULL,
[Measures].[Sales Amount] / [Measures].[Internet Order Count]),
FORMAT_STRING = "Currency",
VISIBLE = 1;
// Mesure 4 - Ventes année précédente
CREATE MEMBER CURRENTCUBE.[Measures].[Sales Amount PY] AS
PARALLELPERIOD(
[Dim Date].[Calendrier].[Calendar Year],
1,
[Dim Date].[Calendrier].CurrentMember),
FORMAT_STRING = "Currency",
VISIBLE = 1;

// Mesure 5 - Croissance YoY
CREATE MEMBER CURRENTCUBE.[Measures].[Sales Growth YoY] AS
IIF(
[Measures].[Sales Amount PY] = 0 
OR [Measures].[Sales Amount PY] IS NULL,
NULL,
([Measures].[Sales Amount] - [Measures].[Sales Amount PY])
/ [Measures].[Sales Amount PY]),
FORMAT_STRING = "#,##0.00%",
VISIBLE = 1;; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
  <Kpis>
    <Kpi dwd:design-time-name="147796f2-e4cc-4409-b7fe-bd964d36587c">
      <ID>Indicateur de performance clé</ID>
      <Name>Revenue Target</Name>
      <Value>[Measures].[Sales Amount]</Value>
      <Goal>5000000</Goal>
      <Status>IIF([Measures].[Sales Amount]/5000000&gt;=1,1,
IIF([Measures].[Sales Amount]/5000000&gt;=0.8,0,-1))</Status>
      <Trend>[Measures].[Sales Growth YoY]</Trend>
      <TrendGraphic>Standard Arrow</TrendGraphic>
      <StatusGraphic>Gauge - Ascending</StatusGraphic>
    </Kpi>
  </Kpis>
</Cube>